generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
}

enum MediaTypeEnum {
  IMAGE
  VIDEO
}

enum BookmarkableType {
  POST
  COMMENT
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  name     String?
  avatar_url String?
  bio      String?
  school   String?
  major    String?
  followers_count Int @default(0) @map("followers_count")
  following_count Int @default(0) @map("following_count")
  password   String
  refresh_token String?
  reset_password_token String?
  reset_password_expires DateTime?
  verify_email_token String?
  verify_email_expires DateTime?
  is_verified Boolean @default(false)
  is_deleted Boolean  @default(false) @map("is_deleted")
  deleted_at DateTime? @map("deleted_at")
  posts    Post[]
  comments Comment[]
  communities CommunityMember[]
  postLikes PostLike[]
  commentLikes CommentLike[]
  notifications Notification[] @relation("NotificationUser")
  triggeredNotifications Notification[] @relation("NotificationActor")
  createdCommunities Community[]
  bookmarks Bookmark[]
  pushTokens PushToken[]
  followers UserFollow[]  @relation("Follower")
  following UserFollow[] @relation("Following")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([is_deleted])
}

model Post {
  id        String   @id @default(uuid())
  content   String
  is_deleted Boolean @default(false) @map("is_deleted")
  deleted_at DateTime? @map("deleted_at")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  comments Comment[]
  likes_count Int @default(0)
  comments_count Int @default(0)
  community Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  communityId String?
  likes PostLike[]
  media PostMedia[]
  notifications Notification[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([communityId])
  @@index([createdAt])
  @@index([communityId, createdAt])
  @@index([is_deleted])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  is_deleted Boolean @default(false) @map("is_deleted")
  deleted_at DateTime? @map("deleted_at")
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  parentId  String?
  parent   Comment?  @relation("Comment", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("Comment")
  likes_count Int @default(0)
  replies_count Int @default(0)
  likes CommentLike[]
  media CommentMedia[]
  notifications Notification[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@index([is_deleted])
}

model Community {
  id        String   @id @default(uuid())
  name      String
  description String?
  avatar_url String?
  is_deleted Boolean  @default(false) @map("is_deleted")
  deleted_at DateTime? @map("deleted_at")
  posts Post[]
  communityMembers CommunityMember[]
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([is_deleted])
}

model CommunityMember {
  id        String   @id @default(uuid())
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  communityId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
}

model PostLike {
  id        String   @id @default(uuid())
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(uuid())
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  type      NotificationType
  title     String
  body      String?
  media_url String?
  redirect_url String?
  read      Boolean @default(false)
  user      User    @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  post      Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)
  postId    String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  commentId String?
  actor User @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  actorId   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model PostMedia {
  id        String   @id @default(uuid())
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  media_url String
  type MediaTypeEnum
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model CommentMedia {
  id        String   @id @default(uuid())
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  media_url String
  type MediaTypeEnum
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model UserFollow {
  id         String   @id @default(uuid())
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId String
  following  User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model PushToken {
  id        String   @id @default(uuid())
  token     String @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

model Bookmark {
  id         String          @id @default(uuid())
  type       BookmarkableType
  entityId   String          @map("entity_id")
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@unique([userId, type, entityId])
  @@index([userId])
  @@index([type, entityId])
}